#include <stdio.h>
#include <stdlib.h>

int main(void) {
	char name[20],i;
	printf("Enter your name");
	for(i=0;i<10;i++){
		scanf("%c",&name[i]);

	}
	printf("Entered name is :");
	for(i=0;i<10;i++){
		printf("%c",name[i]);
	}
	return EXIT_SUCCESS;
}
