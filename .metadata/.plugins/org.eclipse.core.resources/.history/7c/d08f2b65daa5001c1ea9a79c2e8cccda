#include <stdio.h>
#include <stdlib.h>

int main(void) {
	char name[20],i;
	printf("Enter your name");
	scanf("%c",&name);
	for(i=0;i<10;i++){
		printf("Entered name is %c",name[i]);

	}
	return EXIT_SUCCESS;
}
